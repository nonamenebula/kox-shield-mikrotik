add list=to_vpn address=githubassets.com comment="kox-cat:github-dev"
add list=to_vpn address=githubusercontent.com comment="kox-cat:github-dev"
add list=to_vpn address=gitlab.com comment="kox-cat:github-dev"
add list=to_vpn address=hub.docker.com comment="kox-cat:github-dev"
add list=to_vpn address=npmjs.com comment="kox-cat:github-dev"
add list=to_vpn address=npmjs.org comment="kox-cat:github-dev"
