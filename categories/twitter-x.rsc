# KOX Shield — category: Twitter / X (12 entries)
# slug: twitter-x
# Автоматически сгенерировано из portal.db (proxy_routes)
# Запуск: /import file-name=twitter-x.rsc

/ip firewall address-list
add list=to_vpn address=abs.twimg.com comment="kox-cat:twitter-x"
